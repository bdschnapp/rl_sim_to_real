<?xml version="1.0"?>
<!--
  Pruned system component launch.

  Removed: diagnostic_graph (aggregator + utils logging), command_mode, MRM, system_monitor,
  dummy_diag_publisher, component_state_monitor, duplicated_node_checker,
  processing_time_checker. The tier4_system_launch stub now only brings up
  service_log_checker.
-->
<launch>
  <arg name="diagnostic_graph_aggregator_param_path" default=""/>
  <arg name="diagnostic_graph_aggregator_graph_path" default=""/>

  <include file="$(find-pkg-share tier4_system_launch)/launch/system.launch.xml">
    <arg name="run_mode" value="$(var system_run_mode)"/>
    <arg name="launch_system_monitor" value="$(var launch_system_monitor)"/>
    <arg name="launch_dummy_diag_publisher" value="$(var launch_dummy_diag_publisher)"/>
    <arg name="sensor_model" value="$(var sensor_model)"/>
  </include>
</launch>
