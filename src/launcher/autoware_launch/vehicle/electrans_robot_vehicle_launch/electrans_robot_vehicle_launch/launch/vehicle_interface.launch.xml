<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="vehicle_id" default="$(env VEHICLE_ID default)"/>
  <arg name="launch_ros2can_bridge" default="true"/>
  <arg name="launch_canbridge" default="true"/>
  <arg name="can_interface" default="can1"/>
  <arg name="fixed_gear_publish_rate_hz" default="10.0"/>

  <node
    if="$(var launch_ros2can_bridge)"
    pkg="ros2socketcan_bridge"
    exec="ros2can_bridge"
    name="ros2can_bridge"
    args="$(var can_interface)"
    output="screen"/>

  <node
    if="$(var launch_canbridge)"
    pkg="canbridge"
    exec="canbridge"
    name="controller_canbridge"
    output="screen">
    <param name="can_interface" value="$(var can_interface)"/>
  </node>

  <node
    pkg="electrans_robot_vehicle_launch"
    exec="fixed_gear_report_publisher"
    name="fixed_gear_report_publisher"
    output="screen">
    <param name="publish_rate_hz" value="$(var fixed_gear_publish_rate_hz)"/>
  </node>
</launch>
